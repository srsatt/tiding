{
	"name": "tiding",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"start": "bun run src/index.ts",
		"mcp": "bun run src/mcp/server.ts",
		"benchmark:http": "bun run src/benchmark/http-benchmark.ts",
		"build:frontend": "sh build-islands.sh",
		"build:server": "bun build src/index.ts --target=bun --outdir=dist",
		"build": "bun run build:frontend && bun run build:server",
		"compile:server": "bun build --compile src/index.ts --outfile dist/tiding",
		"compile:server:rpi": "bun build --compile --target=bun-linux-arm64 src/index.ts --outfile dist/tiding-linux-arm64",
		"compile:mcp:rpi": "bun build --compile --target=bun-linux-arm64 src/mcp/server.ts --outfile dist/tiding-mcp-linux-arm64",
		"package:rpi": "bun run build:frontend && bun run compile:server:rpi && bun run compile:mcp:rpi && bun run tools/package-rpi.ts",
		"verify:device-http": "bun run tools/verify-device-http.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "bun x biome check .",
		"format": "bun x biome format --write ."
	},
	"dependencies": {
		"@ark-ui/react": "^1.0.0",
		"fast-xml-parser": "^5.9.3",
		"interactjs": "^1.10.27",
		"lucide-react": "^1.23.0",
		"preact": "^10.23.0",
		"preact-iso": "^2.12.0",
		"preact-render-to-string": "^6.7.0",
		"qrcode": "^1.5.4",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"takumi-js": "^2.2.0",
		"ttag": "^1.8.12"
	},
	"devDependencies": {
		"@biomejs/biome": "latest",
		"@types/bun": "latest",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"typescript": "7.0.2"
	}
}
